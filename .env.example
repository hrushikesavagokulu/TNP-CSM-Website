# TMP — CSM Department Web Platform
# Copy this file to .env and fill in values

PORT=5000
MONGO_URI=mongodb://mongo:27017/tmp_db
REDIS_URL=redis://redis:6379
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_EMAIL_DOMAIN=gprec.ac.in

# Phase 1+ (leave blank for now)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=

# Email (Phase 3+)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Drive (Phase 5+)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DRIVE_FOLDER_ID=

# Zoom (Phase 7+)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# MinIO Object Storage (Phase 5+)
# Point MINIO_ENDPOINT at the docker service name for container-to-container calls
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=tnp-uploads
# MINIO_PUBLIC_URL is the URL the BROWSER uses to load files — use localhost in dev
MINIO_PUBLIC_URL=http://localhost:9000
